{
  "name": "@knowvah/dot-core",
  "version": "0.1.0",
  "description": "Framework-agnostic Graphviz DOT → SVG render engine for static-site plugins, powered by the pure-TypeScript graphviz-ts engine.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "graphviz",
    "dot",
    "svg",
    "graphviz-ts",
    "render"
  ],
  "homepage": "https://github.com/knowvah/dot-plugins/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowvah/dot-plugins.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser/index.js",
      "types": "./dist/browser/index.d.ts"
    },
    "./element": {
      "import": "./dist/element/index.js",
      "types": "./dist/element/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@knowvah/dot-engine": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@knowvah/dot-engine": "^1.0.0",
    "jsdom": "^25.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
