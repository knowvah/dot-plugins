{
  "name": "@knowvah/eleventy-plugin-dot",
  "version": "0.1.0",
  "description": "Render Graphviz DOT fenced code blocks to inline SVG in Eleventy (11ty) at build time — powered by the pure-TypeScript graphviz-ts engine.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "eleventy",
    "eleventy-plugin",
    "11ty",
    "graphviz",
    "dot",
    "markdown-it",
    "svg",
    "graphviz-ts"
  ],
  "homepage": "https://github.com/knowvah/dot-plugins/tree/main/packages/eleventy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowvah/dot-plugins.git",
    "directory": "packages/eleventy"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "tsup && cp src/style.css dist/style.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "demo:build": "eleventy --input=demo --output=demo/_site --config=demo/eleventy.config.js"
  },
  "dependencies": {
    "@knowvah/dot-core": "workspace:*",
    "@knowvah/dot-markdown-it": "workspace:*"
  },
  "peerDependencies": {
    "@11ty/eleventy": ">=2.0.0",
    "@knowvah/dot-engine": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@11ty/eleventy": {
      "optional": true
    }
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@knowvah/dot-engine": "^1.0.0",
    "markdown-it": "^14.1.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.12.0"
  }
}
