{
  "name": "@knowvah/dot-react",
  "version": "0.1.0",
  "description": "A React <DotDiagram> component that renders Graphviz DOT to SVG in the browser — powered by the pure-TypeScript @knowvah/dot-engine.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "react",
    "react-component",
    "graphviz",
    "dot",
    "svg",
    "@knowvah/dot-engine",
    "diagram"
  ],
  "homepage": "https://github.com/knowvah/dot-plugins/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowvah/dot-plugins.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "tsup && cp src/style.css dist/style.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@knowvah/dot-core": "workspace:*"
  },
  "peerDependencies": {
    "@knowvah/dot-engine": ">=1.0.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@knowvah/dot-engine": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.12.0"
  }
}
